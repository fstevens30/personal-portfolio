---
import Layout from "../../layouts/Layout.astro";
import { getCollection, render } from "astro:content";
import type { CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post: CollectionEntry<"blog">) => ({
    params: { id: post.id.replace(/\.(md|mdx)$/, "") },
    props: { post },
  }));
}

const { post }: { post: CollectionEntry<"blog"> } = Astro.props;
const { Content } = await render(post);
---

<Layout
  title={`${post.data.title} — Flynn Stevens`}
  description={post.data.description}
>
  <main class="max-w-2xl mx-auto px-4 py-16">
    <div class="mb-8 space-y-2">
      <span class="text-sm text-gray-400">
        {
          post.data.date.toLocaleDateString("en-NZ", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })
        }
      </span>
      <h1
        class="font-semibold text-3xl lg:text-4xl tracking-tight text-gray-900 dark:text-gray-100"
      >
        {post.data.title}
      </h1>
      {
        post.data.description && (
          <p class="text-gray-500 dark:text-gray-400">
            {post.data.description}
          </p>
        )
      }
    </div>
    <hr class="border-gray-200 dark:border-gray-800 mb-8" />
    <article class="prose dark:prose-invert max-w-none">
      <Content />
    </article>
  </main>
</Layout>

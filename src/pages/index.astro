---
import Layout from "../layouts/Layout.astro";
import { ArrowRight, SquareArrowOutUpRight } from "@lucide/astro";

const btnBase =
  "inline-flex items-center gap-1.5 px-4 py-1.5 text-sm rounded-md transition-colors";
const btnAccent = `${btnBase} bg-primary-500 hover:bg-primary-600 text-primary-950 font-medium`;
const btnOutline = `${btnBase} border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 font-medium`;

const links = {
  github: "https://github.com/fstevens30",
  bluesky: "https://bsky.app/profile/flynnstevens.dev",
  linkedin: "https://www.linkedin.com/in/fstevens30/",
  twitter: "https://twitter.com/flynnstevens30",
};

const tech = [
  { name: "Swift", icon: "/icons/swift.svg" },
  { name: "TypeScript", icon: "/icons/typescript.svg" },
  { name: "Next.js", icon: "/icons/nextjs.svg" },
  { name: "Tailwind CSS", icon: "/icons/tailwind.svg" },
  { name: "Supabase", icon: "/icons/supabase.svg" },
  { name: "C#", icon: "/icons/csharp.svg" },
  { name: "OpenStreetMap", icon: "/icons/openstreetmap.svg" },
  { name: "MapLibre", icon: "/icons/maplibre.svg" },
];
---

<Layout
  title="Flynn Stevens"
  description="Junior Software Developer based in Ōtautahi, Aotearoa"
>
  <main class="max-w-2xl mx-auto px-4 py-16 md:py-32">
    <section class="flex flex-col items-center text-center gap-6 pb-16">
      <img
        src="/images/profile.jpeg"
        alt="Flynn Stevens"
        width="120"
        height="120"
        class="rounded-full"
      />
      <div class="space-y-2">
        <h1
          class="text-3xl md:text-4xl font-black tracking-tight text-gray-900 dark:text-gray-100"
        >
          Kia Ora, I'm Flynn
        </h1>
        <p
          class="text-base md:text-lg text-gray-500 dark:text-gray-400 max-w-md mx-auto"
        >
          Junior Software Developer based in Ōtautahi, Aotearoa. Working on
          web-based mapping applications and .NET MAUI mobile apps.
        </p>
      </div>
      <div class="flex gap-3 flex-wrap">
        <a href="/projects" class={btnAccent}>
          View projects <ArrowRight size={14} />
        </a>
        <a href="/about" class={btnOutline}>
          About me <ArrowRight size={14} />
        </a>
      </div>

      <!-- Social links -->
      <p class="text-sm text-gray-400 mt-6">Connect with me</p>
      <div class="flex gap-3 flex-wrap">
        {
          [
            { href: links.github, label: "GitHub" },
            { href: links.bluesky, label: "Bluesky" },
            { href: links.linkedin, label: "LinkedIn" },
            { href: links.twitter, label: "Twitter" },
          ].map(({ href, label }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class={btnOutline}
            >
              {label} <SquareArrowOutUpRight size={12} />
            </a>
          ))
        }
      </div>
    </section>

    <section
      id="portfolio"
      class="py-10 border-t border-gray-100 dark:border-gray-800 space-y-2 scroll-mt-24"
    >
      <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400">
        Portfolio
      </h2>
      <p class="text-gray-600 dark:text-gray-400">
        A few kinds of work I like to build: web mapping applications, mobile
        apps, and polished front-end systems.
      </p>
    </section>

    <section
      id="about"
      class="py-10 border-t border-gray-100 dark:border-gray-800 space-y-2 scroll-mt-24"
    >
      <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400">
        About
      </h2>
      <p class="text-gray-600 dark:text-gray-400">
        Recently completed a Bachelor of Information Technology at Ara Institute
        of Canterbury, specialising in Software Development with distinction.
      </p>
    </section>

    <section
      class="py-10 border-t border-gray-100 dark:border-gray-800 space-y-4"
    >
      <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400">
        Tech
      </h2>
      <p class="text-gray-600 dark:text-gray-400">
        Technologies I have experience with and enjoy working with.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
        {
          tech.map((t) => (
            <div class="flex items-center gap-2 border border-gray-100 dark:border-gray-800 rounded-md px-3 py-2 text-sm">
              <img src={t.icon} alt={t.name} width="36" height="36" />
              <span class="text-gray-900 dark:text-gray-100">{t.name}</span>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>

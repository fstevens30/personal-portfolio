---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";

const links = {
  github: "https://github.com/fstevens30",
  bluesky: "https://bsky.app/profile/flynnstevens.dev",
  linkedin: "https://www.linkedin.com/in/fstevens30/",
  twitter: "https://twitter.com/flynnstevens30",
};

const socialLinks = [
  { href: links.github, label: "GitHub", icon: "/icons/github.svg" },
  { href: links.bluesky, label: "Bluesky", icon: "/icons/bluesky.svg" },
  { href: links.linkedin, label: "LinkedIn", icon: "/icons/linkedin.svg" },
  { href: links.twitter, label: "Twitter", icon: "/icons/twitter.svg" },
];

const tech = [
  { name: "Swift", icon: "/icons/swift.svg" },
  { name: "TypeScript", icon: "/icons/typescript.svg" },
  { name: "Bun", icon: "/icons/bun.svg" },
  { name: "Next.js", icon: "/icons/nextjs.svg" },
  { name: "PostgreSQL", icon: "/icons/postgresql.svg" },
  { name: "Tailwind CSS", icon: "/icons/tailwind.svg" },
  { name: "Supabase", icon: "/icons/supabase.svg" },
  { name: "Git", icon: "/icons/git.svg" },
  { name: "C#", icon: "/icons/csharp.svg" },
  { name: "OpenStreetMap", icon: "/icons/openstreetmap.svg" },
  { name: "MapLibre", icon: "/icons/maplibre.svg" },
  { name: "Docker", icon: "/icons/docker.svg" },
];
---

<Layout
  title="Flynn Stevens"
  description="Junior Software Developer based in Ōtautahi, Aotearoa"
>
  <main class="max-w-2xl mx-auto px-4 py-16 md:py-32">
    <section class="flex flex-col items-center text-center gap-6 pb-16">
      <img
        src="/images/profile.jpeg"
        alt="Flynn Stevens"
        width="120"
        height="120"
        class="rounded-full"
      />
      <div class="space-y-2">
        <h1
          class="text-3xl md:text-4xl font-black tracking-tight text-gray-900 dark:text-gray-100"
        >
          Kia Ora, I'm Flynn
        </h1>
        <p
          class="text-base md:text-lg text-gray-500 dark:text-gray-400 max-w-md mx-auto"
        >
          Junior Software Developer based in Ōtautahi, Aotearoa. Working on
          web-based mapping applications and cross-platform mobile apps.
        </p>
      </div>
      <div class="flex gap-2 flex-wrap justify-center">
        <Button href="/projects" text="See my projects" primary={true} />
        <Button href="/blog" text="Read my blog" primary={false} />
      </div>

      <!-- Social links -->
      <p class="text-sm text-gray-400 mt-6">Connect with me</p>
      <div class="flex gap-2 flex-wrap justify-center">
        {
          socialLinks.map(({ href, label, icon }) => (
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors border border-gray-200 dark:border-gray-700"
              aria-label={label}
            >
              <img
                src={icon}
                alt={label}
                class="w-6 h-6 dark:invert"
                loading="lazy"
              />
            </a>
          ))
        }
      </div>
    </section>

    <section
      class="py-10 border-t border-gray-100 dark:border-gray-800 space-y-4"
    >
      <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400">
        About Me
      </h2>
      <p class="text-gray-600 dark:text-gray-400">
        I enjoying working with web and mobile technologies, as well as mapping
        and geospatial tools. I enjoy learning new technologies and solving
        problems.
      </p>
      <p class="text-gray-600 dark:text-gray-400">
        I am a Junior Software Developer at{" "}
        <a
          href="https://madcapdairysoftware.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-600 underline hover:text-primary-700 dark:text-primary-300 dark:hover:text-primary-400"
          >Contec Group International</a
        >
        where I work on mapping applications for the dairy industry.
      </p>
    </section>

    <section
      class="py-10 border-t border-gray-100 dark:border-gray-800 space-y-4"
    >
      <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400">
        Tech
      </h2>
      <p class="text-gray-600 dark:text-gray-400">
        Technologies I am most familiar with and enjoy the most. To see what I
        use most day-to-day, check out my{" "}<a
          href="https://wakatime.com/@fstevens30"
          target="_blank"
          rel="noopener noreferrer"
          class="text-primary-600 underline hover:text-primary-700 dark:text-primary-300 dark:hover:text-primary-400"
          >WakaTime</a
        >
        profile.
      </p>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-2">
        {
          tech.map((t) => (
            <div class="flex flex-col items-center gap-1 p-4">
              <img src={t.icon} alt={t.name} class="w-16 h-16" />
              <span class="text-sm text-gray-700 dark:text-gray-300">
                {t.name}
              </span>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>

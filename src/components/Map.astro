---
interface Props {
  latitude?: number;
  longitude?: number;
  zoom?: number;
  style?: string;
}

const { latitude = 0, longitude = 0, zoom = 10 } = Astro.props;

declare global {
  interface Window {
    __mapConfig: {
      latitude: number;
      longitude: number;
      zoom: number;
      style: string;
    };
  }
}
---

<div id="map" style="width: 100%; height: 400px;"></div>
<link
  rel="stylesheet"
  href="https://unpkg.com/maplibre-gl/dist/maplibre-gl.css"
/>

<script define:vars={{ latitude, longitude, zoom }}>
  const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
  window.__mapConfig = {
    latitude,
    longitude,
    zoom,
    style: prefersDark
      ? "https://tiles.openfreemap.org/styles/dark"
      : "https://tiles.openfreemap.org/styles/bright",
    // style: {
    //   version: 8,
    //   sources: {
    //     satellite: {
    //       type: "raster",
    //       tiles: [
    //         "https://mt0.google.com/vt/lyrs=s&x={x}&y={y}&z={z}",
    //         "https://mt1.google.com/vt/lyrs=s&x={x}&y={y}&z={z}",
    //         "https://mt2.google.com/vt/lyrs=s&x={x}&y={y}&z={z}",
    //         "https://mt3.google.com/vt/lyrs=s&x={x}&y={y}&z={z}",
    //       ],
    //       tileSize: 256,
    //     },
    //     // ── Elevation data ──────────────────────────
    //     terrarium: {
    //       type: "raster-dem",
    //       tiles: [
    //         "https://s3.amazonaws.com/elevation-tiles-prod/terrarium/{z}/{x}/{y}.png",
    //       ],
    //       tileSize: 256,
    //       encoding: "terrarium",
    //     },
    //   },
    //   layers: [{ id: "satellite", type: "raster", source: "satellite" }],
    //   // ── Enable 3D terrain from elevation source ──
    //   terrain: { source: "terrarium", exaggeration: 1.5 },
    // },
  };
</script>

<script>
  import maplibregl from "maplibre-gl";

  const { latitude, longitude, zoom, style } = (window as any).__mapConfig;

  const map = new maplibregl.Map({
    container: "map",
    style,
    center: [longitude, latitude],
    zoom,
  });

  map.addControl(
    new maplibregl.NavigationControl({
      visualizePitch: true,
      visualizeRoll: true,
      showZoom: true,
      showCompass: true,
    }),
  );
  map.addControl(new maplibregl.ScaleControl());

new maplibregl.Marker({ color: "grey" })
  .setLngLat([168.3470, -46.4118])
  .addTo(map);

new maplibregl.Marker({ color: "grey" })
  .setLngLat([173.2838, -41.2743])
  .addTo(map);

new maplibregl.Marker({ color: "#facc15" })
  .setLngLat([172.6366, -43.5309])
  .addTo(map);
</script>
